import { B as Beliefs } from './client-IVkquQfr.cjs';
import { HookEvent, HookCallbackMatcher } from '@anthropic-ai/claude-agent-sdk';
import 'zod';

/**
 * Claude Agent SDK hooks for beliefs.
 *
 * Provides hook handlers compatible with the Claude Agent SDK's
 * hook system. Automatically captures tool results as observations
 * and injects belief context at session start.
 *
 * @example
 * ```ts
 * import Beliefs from 'beliefs'
 * import { beliefsHooks } from 'beliefs/claude-agent-sdk'
 *
 * const beliefs = new Beliefs({ apiKey: process.env.BELIEFS_KEY })
 * const hooks = beliefsHooks(beliefs)
 *
 * const result = await query({
 *   prompt: 'Research AI tools market',
 *   options: { hooks },
 * })
 * ```
 */

type CaptureMode = 'tools' | 'all';
interface BeliefsHooksOptions {
    /** What to capture. 'tools' = tool results only (default). 'all' = tool results + text responses. */
    capture?: CaptureMode;
    /** Inject belief context at session start. Default: true. */
    includeContext?: boolean;
    /** Tool name regex to filter which tools trigger belief extraction. Default: match all. */
    toolFilter?: string;
}
declare function beliefsHooks(beliefs: Beliefs, options?: BeliefsHooksOptions): Partial<Record<HookEvent, HookCallbackMatcher[]>>;

export { type BeliefsHooksOptions, type CaptureMode, beliefsHooks };
