{
  "name": "beliefs",
  "version": "0.2.1",
  "description": "Belief-state runtime for AI agents. Track what your agent believes, how confident it is, and why.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vercel-ai": {
      "import": {
        "types": "./dist/vercel-ai.d.ts",
        "default": "./dist/vercel-ai.js"
      },
      "require": {
        "types": "./dist/vercel-ai.d.cts",
        "default": "./dist/vercel-ai.cjs"
      }
    },
    "./claude-agent-sdk": {
      "import": {
        "types": "./dist/claude-agent-sdk.d.ts",
        "default": "./dist/claude-agent-sdk.js"
      },
      "require": {
        "types": "./dist/claude-agent-sdk.d.cts",
        "default": "./dist/claude-agent-sdk.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agents",
    "beliefs",
    "belief-state",
    "confidence",
    "fusion",
    "llm",
    "reasoning",
    "provenance",
    "bayesian",
    "sdk"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkn-ai/beliefs"
  },
  "homepage": "https://thinkn.ai/dev",
  "bugs": {
    "url": "https://github.com/thinkn-ai/beliefs/issues"
  },
  "author": "Thinkn <devs@thinkn.ai>",
  "peerDependencies": {
    "ai": ">=4.0.0",
    "@anthropic-ai/claude-agent-sdk": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "@anthropic-ai/claude-agent-sdk": { "optional": true }
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/anthropic": "^3.0.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.12",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
